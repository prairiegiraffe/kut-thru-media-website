---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Pitch | KUT | THRŪ Media" noindex={true}>
  <Header />

  <main class="flex-1">
    <section class="section relative min-h-screen flex items-center bg-charcoal">
      <div class="container relative z-10 pt-20">
        <div class="max-w-5xl mx-auto">
          <iframe
            src="https://devtools.prairiegiraffe.com/pitch/gsfeyc6ecgbtiw6v"
            width="100%"
            height="900"
            frameborder="0"
            style="border:none; border-radius:8px;"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
