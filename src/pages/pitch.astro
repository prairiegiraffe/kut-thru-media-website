---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Pitch | KUT | THRŪ Media" noindex={true}>
  <Header />

  <main class="flex-1">
    <section class="relative bg-charcoal pt-20" style="height: calc(100vh - 80px);">
      <iframe
        src="https://devtools.prairiegiraffe.com/pitch/gsfeyc6ecgbtiw6v"
        width="100%"
        height="100%"
        style="border:none; display:block;"
        loading="lazy"
      ></iframe>
    </section>
  </main>
</Layout>

<style is:global>
  /* Hide custom cursor on this page — iframe captures mouse events */
  .cursor { display: none !important; }
</style>
