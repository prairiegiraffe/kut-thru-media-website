---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';
---

<Layout
  title="The Kut Through Podcast (Coming Soon) | KUT | THRŪ Media"
  description="Something's brewing for the people who build, power, and fuel this country. Stay tuned."
>
  <Header />

  <main class="flex-1 pt-20">
    <!-- Hero Section -->
    <section class="section bg-gradient-to-b from-gray-900 to-charcoal min-h-[60vh] flex items-center">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center">
          <span class="eyebrow block mb-4">Coming Soon</span>
          <h1 class="headline-xl mb-6">The Kut Through Podcast</h1>
          <p class="body-lg text-muted">
            Real conversations with the men and women in the field.
          </p>
        </div>
      </div>
    </section>

    <!-- Content Section -->
    <section class="section bg-charcoal">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <div class="w-24 h-24 mx-auto mb-8 bg-power-red/20 rounded-full flex items-center justify-center">
            <svg class="w-12 h-12 text-power-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>

          <h2 class="headline-md mb-6">Something's Brewing</h2>
          <p class="body-lg text-muted mb-12">
            We're working on something for the people who build, power, and fuel this country. Real conversations with the men and women in the field.
          </p>
          <p class="text-2xl font-bold text-power-red mb-12">Stay tuned.</p>

          <!-- Email Signup Form -->
          <div class="card max-w-md mx-auto">
            <h3 class="text-xl font-bold mb-6">Get Notified When We Launch</h3>
            <form class="space-y-4">
              <div>
                <label for="email" class="sr-only">Email address</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="Enter your email"
                  required
                  class="w-full px-4 py-3 bg-gray-900 border border-white/20 text-impact-white placeholder-text-subtle focus:border-power-red focus:outline-none transition-colors"
                />
              </div>
              <Button type="submit" variant="primary" class="w-full">
                Notify Me
              </Button>
            </form>
            <p class="text-sm text-text-subtle mt-4">
              We respect your privacy. Unsubscribe at any time.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Teaser Section -->
    <section class="section bg-gray-900">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-5xl mx-auto">
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-power-red/20 rounded-lg flex items-center justify-center">
              <svg class="w-8 h-8 text-power-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">Real People</h3>
            <p class="text-muted text-sm">Stories from the field</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-power-red/20 rounded-lg flex items-center justify-center">
              <svg class="w-8 h-8 text-power-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">Raw Conversations</h3>
            <p class="text-muted text-sm">No fluff, no scripts</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-power-red/20 rounded-lg flex items-center justify-center">
              <svg class="w-8 h-8 text-power-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">Industry Focus</h3>
            <p class="text-muted text-sm">Blue collar business</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-power-red/20 rounded-lg flex items-center justify-center">
              <!-- Horse head icon -->
              <svg class="w-8 h-8 text-power-red" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 3c-.8 0-1.4.3-1.9.7L16 3c-.6 0-1.1.1-1.6.3C13.6 3.1 12.8 3 12 3c-2.2 0-4.1 1-5.4 2.5L5 7H3v2h1.2l-.7 2H2v2h1l-.5 1.5C2.2 15.6 2 16.3 2 17c0 1.7 1.3 3 3 3h1v-2H5c-.6 0-1-.4-1-1 0-.5.1-1 .4-1.5L5 14h1.5l1 3H10v-2H8.7l-.5-1.5.3-.5H11v2.5c0 .8.7 1.5 1.5 1.5s1.5-.7 1.5-1.5V14c1.1 0 2-.9 2-2v-1.6c.9-.7 1.5-1.8 1.5-3 0-.3 0-.6-.1-.9l1.6-.8c.3-.1.5-.4.5-.7V3zm-7 9c-.6 0-1-.4-1-1s.4-1 1-1 1 .4 1 1-.4 1-1 1z"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">A Little Horseshit</h3>
            <p class="text-muted text-sm">Keep it real</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
