---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';
---

<Layout
  title="The Kut Through Podcast (Coming Soon) | KUT | THRŪ Media"
  description="Something's brewing for the people who build, power, and fuel this country. Stay tuned."
>
  <Header />

  <main class="flex-1">
    <!-- Hero Section -->
    <section class="section relative overflow-hidden min-h-[60vh] flex items-center">
      <div class="absolute inset-0 bg-charcoal">
        <div class="absolute inset-0 opacity-40" style="background-image: url('/assets/images/podcast/102A7420.jpg'); background-size: cover; background-position: center;"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/60 to-charcoal/30"></div>
      </div>
      <div class="container relative z-10 pt-20">
        <div class="max-w-3xl mx-auto text-center">
          <span class="eyebrow block mb-6">Coming Soon</span>
          <img
            src="/assets/images/podcast/KTM Podcast White (2).png"
            alt="KUT | THRŪ Media Podcast"
            class="w-full max-w-md lg:max-w-lg mx-auto mb-8 px-4"
          />
          <p class="body-lg text-muted">
            Real conversations with the men and women in the field.
          </p>
        </div>
      </div>
    </section>

    <!-- Content Section -->
    <section class="section bg-charcoal">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <div class="w-24 h-24 mx-auto mb-8 bg-power-red/20 rounded-full flex items-center justify-center">
            <svg class="w-12 h-12 text-power-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>

          <h2 class="headline-md mb-6">Something's Brewing</h2>
          <p class="body-lg text-muted mb-12">
            We're working on something for the people who build, power, and fuel this country. Real conversations with the men and women in the field.
          </p>
          <p class="text-2xl font-bold text-power-red mb-12">Stay tuned.</p>

          <!-- Email Signup Form -->
          <div class="card max-w-md mx-auto">
            <div class="relative z-1">
            <h3 class="text-xl font-bold mb-6">Get Notified When We Launch</h3>
            <form class="space-y-4" id="podcast-form">
              <div>
                <label for="podcast-email" class="sr-only">Email address</label>
                <input
                  type="email"
                  id="podcast-email"
                  name="email"
                  placeholder="Enter your email"
                  required
                  class="w-full px-4 py-3 bg-gray-900 border border-white/20 text-impact-white placeholder-text-subtle focus:border-power-red focus:outline-none transition-colors"
                />
              </div>
              <Button type="submit" variant="primary" class="w-full">
                Notify Me
              </Button>
            </form>
            <p id="podcast-success" class="hidden text-sm text-green-400 mt-4 font-semibold">
              You're on the list! We'll let you know when we launch.
            </p>
            <p id="podcast-privacy" class="text-sm text-text-subtle mt-4">
              We respect your privacy. Unsubscribe at any time.
            </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Teaser Section -->
    <section class="section bg-gray-900">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-5xl mx-auto">
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-power-red/20 rounded-lg flex items-center justify-center">
              <svg class="w-8 h-8 text-power-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">Real People</h3>
            <p class="text-muted text-sm">Stories from the field</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-power-red/20 rounded-lg flex items-center justify-center">
              <svg class="w-8 h-8 text-power-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">Raw Conversations</h3>
            <p class="text-muted text-sm">No fluff, no scripts</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-power-red/20 rounded-lg flex items-center justify-center">
              <svg class="w-8 h-8 text-power-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">Industry Focus</h3>
            <p class="text-muted text-sm">Blue collar business</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-power-red/20 rounded-lg flex items-center justify-center">
              <!-- Horse icon -->
              <svg class="w-8 h-8 text-power-red" fill="currentColor" viewBox="0 0 510.215 510.215">
                <path d="m439.472 79.089c-16.373-18.312-39.852-28.814-64.416-28.814h-11.056v-31.333h-30v36.141l-79.694 128.857h-167.297c-47.977 0-87.009 39.032-87.009 87.009v105.127h22.316c14.211 0 27.42-4.362 38.367-11.812v127.009h99.984v-99.189l37.446-39.477h94.889v138.667h99.985v-204.138l31.343-79.116c28.961 11.838 58.398.915 72.086-24.344l13.799-25.465zm-378.789 183.343v45.278c0 18.524-13.198 34.024-30.683 37.594v-74.354c0-27.944 20.216-51.24 46.786-56.073-10.091 13.206-16.103 29.689-16.103 47.555zm212.983-52.761 60.334-97.555v11.477c0 33.602-1.08 68.496-13.99 93.455l-.204.41c-5.323 11.109-23.139 27.548-46.14 27.548zm196.374-40.287c-6.338 11.696-20.382 16.668-32.668 11.568l-29.701-12.333-44.684 112.791v179.863h-39.985v-138.666h-116.335v-38.333h-30v47.351l-46 48.495v81.154h-39.984v-198.842c0-26.739 21.753-48.492 48.492-48.492h104.492v61.066h34.147c30.87 0 58.509-22.821 68.945-44.372 15.907-30.91 17.241-69.825 17.241-107.04v-43.32h11.056c16.036 0 31.363 6.856 42.051 18.811l56.676 63.389z"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">A Little Horseshit</h3>
            <p class="text-muted text-sm">Keep it real</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('podcast-form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      const originalText = btn ? btn.textContent : 'Notify Me';
      if (btn) { btn.disabled = true; btn.textContent = 'Sending...'; }

      try {
        const email = new FormData(form).get('email');

        await fetch('https://devtools.prairiegiraffe.com/api/projects/proj_em8foyyu/submissions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: 'Podcast Subscriber',
            email: email,
            form_type: 'podcast-signup',
            page_url: window.location.href,
          }),
        });

        form.classList.add('hidden');
        const privacy = document.getElementById('podcast-privacy');
        if (privacy) privacy.classList.add('hidden');
        const success = document.getElementById('podcast-success');
        if (success) success.classList.remove('hidden');
      } catch {
        alert('Something went wrong. Please try again.');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = originalText; }
      }
    });
  }
</script>
