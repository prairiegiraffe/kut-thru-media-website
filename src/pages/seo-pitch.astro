---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="SEO | KUT | THRŪ Media" noindex={true}>
  <Header />

  <main class="flex-1">
    <section class="relative bg-charcoal pt-20" style="height: calc(100vh - 80px);">
      <script is:inline src="https://devtools.prairiegiraffe.com/embed.js"
        data-project="proj_em8foyyu"
        defer></script>
    </section>
