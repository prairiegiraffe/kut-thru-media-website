---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MarqueeText from '../components/effects/MarqueeText.astro';

const socialLinks = [
  { href: 'https://www.linkedin.com/company/kut-thr%C5%AB-media/', label: 'LinkedIn' },
  { href: 'https://www.facebook.com/people/KUT-THR%C5%AA-Media/61577629271016/', label: 'Facebook' },
  { href: 'https://www.instagram.com/kutthrumedia/', label: 'Instagram' },
  { href: 'https://www.youtube.com/@kutthrumedia', label: 'YouTube' },
  { href: 'https://www.tiktok.com/@kutthrumedia', label: 'TikTok' },
];
---

<Layout
  title="Contact Us | KUT | THRŪ Media"
  description="Ready to KUT | THRŪ the noise? Let's talk about what we can build for your business. Call 307-228-0352 or reach out today."
>
  <Header />

  <main class="flex-1">
    <!-- Hero Section -->
    <section class="relative min-h-[70vh] flex items-end pb-16 overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0 bg-charcoal"></div>
      <!-- Animated lines -->
      <div class="absolute inset-0 overflow-hidden opacity-20">
        <div class="absolute top-0 left-1/4 w-px h-full bg-gradient-to-b from-transparent via-power-red to-transparent"></div>
        <div class="absolute top-0 left-1/2 w-px h-full bg-gradient-to-b from-transparent via-white/20 to-transparent"></div>
        <div class="absolute top-0 left-3/4 w-px h-full bg-gradient-to-b from-transparent via-power-red to-transparent"></div>
      </div>

      <div class="container relative z-10 pt-40">
        <span class="eyebrow block mb-6" data-animate="fade-up">Get in Touch</span>
        <h1 class="headline-hero mb-6" data-animate="fade-up">
          Let's Talk
        </h1>
        <p class="body-lg text-muted max-w-xl" data-animate="fade-up">
          Ready to KUT | THRŪ the noise? We're ready when you are.
        </p>
      </div>
    </section>

    <!-- Marquee -->
    <section class="py-6 border-y border-white/5 bg-charcoal-light overflow-hidden">
      <MarqueeText
        text="LET'S BUILD SOMETHING WORTH TALKING ABOUT"
        speed={15}
        class="text-xl font-bold text-text-subtle/20"
      />
    </section>

    <!-- Contact Content -->
    <section class="section bg-charcoal">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-32">
          <!-- Contact Form -->
          <div data-animate="slide-left">
            <h2 class="headline-md mb-4">Send Us a Message</h2>
            <p class="text-muted mb-12">Fill out the form and we'll get back to you within 24 hours.</p>

            <div id="dt-form-contact-form"></div>
            <script is:inline src="https://devtools.prairiegiraffe.com/form-embed.js?v=2"
              data-project="proj_em8foyyu"
              data-form="contact-form"
              data-target="dt-form-contact-form"
              defer></script>
          </div>

          <!-- Contact Info -->
          <div data-animate="slide-right">
            <h2 class="headline-md mb-4">Contact Info</h2>
            <p class="text-muted mb-12">Prefer to reach out directly? Here's how to find us.</p>

            <div class="space-y-12">
              <!-- Email -->
              <div class="group">
                <span class="block text-xs font-bold text-text-subtle uppercase tracking-widest mb-3">Email</span>
                <a href="mailto:info@kutthru.com" class="text-3xl lg:text-4xl font-bold link-hover group-hover:text-power-red transition-colors">
                  info@kutthru.com
                </a>
              </div>

              <!-- Phone -->
              <div class="group">
                <span class="block text-xs font-bold text-text-subtle uppercase tracking-widest mb-3">Phone</span>
                <a href="tel:307-228-0352" class="text-3xl lg:text-4xl font-bold link-hover group-hover:text-power-red transition-colors">
                  307-228-0352
                </a>
              </div>

              <!-- Address -->
              <div>
                <span class="block text-xs font-bold text-text-subtle uppercase tracking-widest mb-3">Address</span>
                <address class="text-xl lg:text-2xl not-italic text-muted leading-relaxed">
                  1701 Phillips Cir. STE 110<br />
                  Gillette, WY 82718
                </address>
              </div>
            </div>

            <!-- Social Links -->
            <div class="mt-16 pt-12 border-t border-white/10">
              <span class="block text-xs font-bold text-text-subtle uppercase tracking-widest mb-6">Follow Us</span>
              <div class="flex flex-wrap gap-3">
                {socialLinks.map((link) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="px-6 py-3 border border-white/10 text-sm font-semibold uppercase tracking-wider hover:bg-power-red hover:border-power-red transition-all duration-300"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map Section -->
    <section class="relative h-[50vh] bg-gray-900">
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-6 border border-white/10 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-power-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <p class="text-2xl font-bold mb-2">Gillette, Wyoming</p>
          <p class="text-muted">The heart of energy country</p>
        </div>
      </div>
      <!-- Decorative grid -->
      <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 50px 50px;"></div>
    </section>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* DevTools form embed — match Kut-Thru dark theme */
  .dt-form__label {
    color: rgba(255, 255, 255, 0.5) !important;
    font-size: 0.75rem !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
  }

  .dt-form__input,
  .dt-form select,
  .dt-form textarea {
    background: transparent !important;
    border: none !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
    border-radius: 0 !important;
    color: var(--color-impact-white) !important;
    font-size: 1.125rem !important;
    padding: 1rem 0 !important;
    transition: border-color 0.3s ease !important;
  }

  .dt-form__input:focus,
  .dt-form select:focus,
  .dt-form textarea:focus {
    outline: none !important;
    border-bottom-color: var(--color-power-red) !important;
    box-shadow: none !important;
  }

  .dt-form__input::placeholder {
    color: var(--color-text-subtle) !important;
  }

  .dt-form__submit {
    background: var(--color-power-red) !important;
    border: none !important;
    color: var(--color-impact-white) !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    padding: 1rem 2.5rem !important;
    font-size: 0.875rem !important;
    cursor: pointer !important;
    transition: opacity 0.3s ease !important;
  }

  .dt-form__submit:hover {
    opacity: 0.9 !important;
  }

  .dt-form__field {
    margin-bottom: 1.5rem !important;
  }

  .dt-form__status {
    color: #4ade80 !important;
    background: rgba(74, 222, 128, 0.05) !important;
    border: 1px solid rgba(74, 222, 128, 0.2) !important;
  }
</style>
